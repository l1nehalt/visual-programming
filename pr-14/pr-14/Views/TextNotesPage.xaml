<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="pr_14.Views.TextNotesPage"
             Title="Text Notes"
             BackgroundColor="#F5F5F5">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="ADD"
                     Clicked="OnAddClicked"/>
    </ContentPage.ToolbarItems>

    <Grid Padding="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollView Grid.Row="0"
                    x:Name="editForm"
                    IsVisible="False">

            <StackLayout Spacing="12">

                <Frame CornerRadius="12"
                       Padding="10"
                       HasShadow="True"
                       BackgroundColor="White">

                    <Entry x:Name="noteTitleEntry"
                           Placeholder="Название заметки"
                           PlaceholderColor="Gray"
                           TextColor="Black"
                           FontAttributes="Bold"/>
                </Frame>

                <Frame CornerRadius="12"
                       Padding="10"
                       HasShadow="True"
                       BackgroundColor="White">

                    <Editor x:Name="editor"
                            HeightRequest="120"
                            TextColor="Black"
                            PlaceholderColor="Gray"
                            Placeholder="Текст заметки"/>
                </Frame>

                <Frame x:Name="imageContainer"
                       CornerRadius="12"
                       Padding="0"
                       HasShadow="True"
                       HeightRequest="220"
                       IsClippedToBounds="True"
                       IsVisible="False" 
                       BackgroundColor="White">

                    <Image x:Name="noteImage"
                           Aspect="AspectFill"/>
                </Frame>

                <Button Text="📷 Выбрать изображение"
                        HeightRequest="50"
                        CornerRadius="12"
                        BackgroundColor="#607D8B"
                        TextColor="White"
                        Clicked="OnSelectImageClicked"/>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Text="Сохранить"
                            HeightRequest="50"
                            CornerRadius="12"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            Clicked="OnSaveButtonClicked"/>

                    <Button Grid.Column="1"
                            Text="Удалить"
                            HeightRequest="50"
                            CornerRadius="12"
                            BackgroundColor="#F44336"
                            TextColor="White"
                            Clicked="OnDeleteButtonClicked"/>
                </Grid>

            </StackLayout>

        </ScrollView>

        <CollectionView Grid.Row="1"
                        x:Name="collectionView"
                        Margin="0,15,0,0"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Margin="0,5"
                           Padding="10"
                           CornerRadius="12"
                           BackgroundColor="White"
                           HasShadow="True">

                        <Grid ColumnSpacing="12">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Frame Grid.Column="0"
                                   Padding="0"
                                   CornerRadius="8"
                                   IsClippedToBounds="True"
                                   HeightRequest="60"
                                   WidthRequest="60">

                                <Image Source="{Binding ImagePath}"
                                       Aspect="AspectFill"/>
                            </Frame>

                            <StackLayout Grid.Column="1"
                                         VerticalOptions="Center">

                                <Label Text="{Binding Text}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#212121"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"/>

                                <Label Text="{Binding Date, StringFormat='{0:dd.MM.yyyy HH:mm}'}"
                                       FontSize="12"
                                       TextColor="#757575"/>
                            </StackLayout>

                        </Grid>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>