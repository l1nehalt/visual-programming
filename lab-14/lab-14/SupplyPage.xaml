<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="lab_14.SupplyPage" Title="Информация о поставке">
    <StackLayout Padding="20">

        <Label Text="Выберите Поставщика" FontAttributes="Bold"/>
        <Picker x:Name="supplierPicker" Title="-- Нажмите для выбора --" ItemDisplayBinding="{Binding Name}" />

        <Label Text="Выберите Товар" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Picker x:Name="itemPicker" Title="-- Нажмите для выбора --" ItemDisplayBinding="{Binding Name}" />

        <Label Text="Объем поставки" FontAttributes="Bold" Margin="0,10,0,0"/>
        <Entry x:Name="entryVolume" Keyboard="Numeric" Placeholder="Введите количество" />

        <StackLayout Orientation="Horizontal" Margin="0,20,0,0">
            <Button Text="Сохранить" Clicked="SaveSupply_Clicked"/>
            <Button x:Name="btnDelete" Text="Удалить" Clicked="DeleteSupply_Clicked"/>
        </StackLayout>
    </StackLayout>
</ContentPage>